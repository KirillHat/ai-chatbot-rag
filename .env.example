# --- Anthropic Claude API ---
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# Default model for chat completion
CLAUDE_MODEL=claude-sonnet-4-6
# Max tokens in the assistant reply
CLAUDE_MAX_TOKENS=1024

# --- Admin auth ---
# Token used by the admin panel to upload / delete documents.
# Sent as `Authorization: Bearer <token>`. Must be 16+ chars in production.
ADMIN_API_TOKEN=change-me-to-a-long-random-string

# --- Storage ---
# Where ChromaDB persists its vectors and SQLite stores doc/chat metadata.
CHROMA_DIR=./data/chroma
SQLITE_PATH=./data/app.db
UPLOAD_DIR=./data/uploads

# --- Retrieval / chunking ---
CHUNK_SIZE=900
CHUNK_OVERLAP=150
TOP_K=4
# Wider candidate pool fed to BM25/vector hybrid before trim to TOP_K.
# Should be 3-4× TOP_K. With re-ranking enabled, raise to 16-32.
RETRIEVAL_POOL=16
# Embedding model:
#   default       — bundled English-only ONNX MiniLM-L6-v2 (no extra deps)
#   multilingual  — paraphrase-multilingual-MiniLM-L12-v2 (50+ languages incl. Russian)
#                   needs `pip install sentence-transformers`
#   none          — disable embeddings entirely; rely on BM25 alone (mostly used by tests)
#   <any st-id>   — pass a sentence-transformers model id directly
EMBEDDING_MODEL=default
# Hybrid retrieval weight: 1.0 = pure vector, 0.0 = pure BM25, 0.6 = balanced.
HYBRID_ALPHA=0.6

# --- Optional re-ranking (off by default) ---
# Boosts retrieval quality ~20-30% by sending the top-N candidates through
# a cross-encoder. Adds ~150 ms latency per query.
#   none   — disabled (default)
#   cohere — uses rerank-multilingual-v3.0 (multilingual). Needs COHERE_API_KEY.
RERANK_PROVIDER=none
COHERE_API_KEY=

# --- Hand-off / escalation (off by default) ---
# When a user clicks "Talk to a human" in the widget, we POST a payload
# here. Set either or both — empty values just log the escalation locally.
ESCALATION_SLACK_WEBHOOK=
ESCALATION_EMAIL=

# --- Server ---
HOST=0.0.0.0
PORT=8000
# Comma-separated list of origins allowed to call /chat from the widget.
# Use "*" to allow embedding on any site (fine for the public demo).
CORS_ORIGINS=*

# --- Rate limiting ---
# Requests per minute per IP for the /chat endpoint.
RATE_LIMIT_PER_MINUTE=20

# --- Tenant ---
# Display name shown in the widget header and used in the system prompt.
ASSISTANT_NAME=AI Assistant
ASSISTANT_TENANT=demo
