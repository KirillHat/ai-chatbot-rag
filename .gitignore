.env
.env.local
*.pyc
__pycache__/
.venv/
venv/
.pytest_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
*.egg-info/
build/
dist/
.DS_Store
.idea/
.vscode/

# Runtime data — keep the directories (via .gitkeep) but never commit user data.
data/chroma/*
!data/chroma/.gitkeep
data/uploads/*
!data/uploads/.gitkeep
data/app.db
data/app.db-*
*.log

# SQLite catch-all — defends against forks that put a DB at a different path.
*.db
*.db-journal
*.sqlite
*.sqlite3
